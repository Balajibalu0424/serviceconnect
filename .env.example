# ============================================================
# ServiceConnect - Environment Variables
# ============================================================
# Copy this file to .env for local development.
# For Vercel, add each variable in Project Settings -> Environment Variables.

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/serviceconnect

# Auth
JWT_SECRET=replace_with_a_long_random_jwt_secret
REFRESH_SECRET=replace_with_a_long_random_refresh_secret
NODE_ENV=development
APP_URL=http://localhost:5000

# Auth (Clerk migration)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_secret_here
# Legacy frontend alias for older environments only.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
# Legacy fallback for older environments only.
VITE_STRIPE_PUBLIC_KEY=

# Email / OTP Delivery (Resend)
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=ServiceConnect <no-reply@example.com>

# SMS OTP (Twilio Verify)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OTP_DEFAULT_COUNTRY_CODE=+353
# Leave false in production. Only enable locally when intentionally testing fallback OTP delivery.
OTP_ALLOW_DEV_FALLBACK=false

# Uploads (Vercel Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token_here

# AI providers
GEMINI_API_KEY=your_gemini_api_key_here
HUGGINGFACE_API_KEY=hf_your_huggingface_token_here

# Realtime notifications
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=eu
VITE_PUSHER_KEY=your_pusher_key
VITE_PUSHER_CLUSTER=eu
