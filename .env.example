# ============================================================
# ServiceConnect — Environment Variables
# ============================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For Vercel: add each variable in
#   Project Settings → Environment Variables
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Local dev (PostgreSQL running on your machine):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/serviceconnect

# Production (Neon — replace with your actual Neon connection string):
# DATABASE_URL=postgresql://neondb_owner:xxxx@ep-xxx.eu-west-2.aws.neon.tech/neondb?sslmode=require

# ── JWT Auth ─────────────────────────────────────────────────
# CHANGE THIS to a long random string in production!
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=serviceconnect-jwt-secret-dev-2024

# ── Node ─────────────────────────────────────────────────────
NODE_ENV=development

# ── Stripe (Payments) ────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here

# ── Google Gemini AI ─────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Powers: job description enhancement, smart category detection,
#         fraud analysis, quote suggestions, AI chat, pro matching,
#         review summaries, bio enhancement, onboarding chat
GEMINI_API_KEY=your_gemini_api_key_here

# ── HuggingFace (NER / Entity Extraction) ────────────────────
# Get from: https://huggingface.co/settings/tokens
# Used for named-entity recognition in job descriptions
HUGGINGFACE_API_KEY=hf_your_huggingface_token_here

# ── Pusher (Real-time Notifications) ─────────────────────────
# Get from: https://dashboard.pusher.com — create a Channels app
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=eu

# Client-side Pusher key (must match PUSHER_KEY)
VITE_PUSHER_KEY=your_pusher_key
VITE_PUSHER_CLUSTER=eu

# ── Optional: App URL ─────────────────────────────────────────
# Used for CORS and redirect URLs
APP_URL=http://localhost:5000
