# ============================================================
# ServiceConnect — Environment Variables
# ============================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For Vercel: add each variable in
#   Project Settings → Environment Variables
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Local dev (PostgreSQL running on your machine):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/serviceconnect

# Production (Neon — replace with your actual Neon connection string):
# DATABASE_URL=postgresql://neondb_owner:xxxx@ep-xxx.eu-west-2.aws.neon.tech/neondb?sslmode=require

# ── JWT Auth ─────────────────────────────────────────────────
# CHANGE THIS to a long random string in production!
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=serviceconnect-jwt-secret-dev-2024

# ── Node ─────────────────────────────────────────────────────
NODE_ENV=development

# ── Stripe (Payments) ────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here

# ── Optional: App URL ─────────────────────────────────────────
# Used for CORS and redirect URLs
APP_URL=http://localhost:5000
